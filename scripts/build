#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="${ROOT_DIR}/.venv/bin/python"

if [ ! -x "${PYTHON_BIN}" ]; then
  echo "ContextWeave is not bootstrapped yet." >&2
  echo "Run: ./scripts/bootstrap" >&2
  exit 1
fi

"${PYTHON_BIN}" -m pip install build
"${PYTHON_BIN}" -m build --no-isolation
"${ROOT_DIR}/scripts/check-dist"
